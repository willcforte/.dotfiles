{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "Monitor",
      "LSP",
      "Skill(update-config:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git revert:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git tag:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git apply:*)",
      "Bash(git -C * status:*)",
      "Bash(git -C * diff:*)",
      "Bash(git -C * log:*)",
      "Bash(git -C * show:*)",
      "Bash(git -C * branch:*)",
      "Bash(git -C * fetch:*)",
      "Bash(git -C * remote:*)",
      "Bash(git -C * rev-parse:*)",
      "Bash(git -C * add:*)",
      "Bash(git -C * commit:*)",
      "Bash(git -C * revert:*)",
      "Bash(git -C * checkout:*)",
      "Bash(git -C * switch:*)",
      "Bash(git -C * merge:*)",
      "Bash(git -C * rebase:*)",
      "Bash(git -C * stash:*)",
      "Bash(git -C * reset:*)",
      "Bash(git -C * restore:*)",
      "Bash(git -C * cherry-pick:*)",
      "Bash(git -C * tag:*)",
      "Bash(git -C * rm:*)",
      "Bash(git -C * mv:*)",
      "Bash(git -C * apply:*)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(tailscale status *)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git clean:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git -C * push:*)",
      "Bash(git -C * pull:*)",
      "Bash(git -C * clone:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": false
}
