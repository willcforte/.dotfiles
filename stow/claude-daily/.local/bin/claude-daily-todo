#!/usr/bin/env bash
# claude-daily-todo
#
# Generate today's prioritized to-do list and append it to the Obsidian
# daily note for today. Runs non-interactively via the `claude` CLI, which
# uses whatever MCP servers are configured (gmail, gcal, github, slack, ...)
# to gather context.

set -euo pipefail

# --- Config (override via env) ----------------------------------------------
OBSIDIAN_VAULT="${OBSIDIAN_VAULT:-$HOME/Obsidian}"
DAILY_NOTES_DIR="${DAILY_NOTES_DIR:-$OBSIDIAN_VAULT/Daily Notes}"
LOOKBACK_DAYS="${CLAUDE_DAILY_LOOKBACK_DAYS:-7}"
MAX_ITEMS="${CLAUDE_DAILY_MAX_ITEMS:-10}"
SECTION_HEADER="## Claude's Daily Plan"

# --- Setup ------------------------------------------------------------------
export PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude-daily-todo"
mkdir -p "$STATE_DIR"
LOG_FILE="$STATE_DIR/run-$(date +%Y-%m-%d).log"
exec >>"$LOG_FILE" 2>&1
echo "===== $(date -Is) start ====="

if ! command -v claude >/dev/null 2>&1; then
  echo "claude CLI not found on PATH" >&2
  exit 1
fi

TODAY="$(date +%Y-%m-%d)"
TODAY_HUMAN="$(date '+%A, %B %d, %Y')"
DAILY_NOTE="$DAILY_NOTES_DIR/$TODAY.md"
mkdir -p "$DAILY_NOTES_DIR"

# Skip if today's section is already present (re-runs, manual invocations)
if [ -f "$DAILY_NOTE" ] && grep -qF "$SECTION_HEADER" "$DAILY_NOTE"; then
  echo "Section already present in $DAILY_NOTE — skipping."
  exit 0
fi

# --- Build prompt -----------------------------------------------------------
PROMPT=$(cat <<EOF
You are generating my prioritized to-do list for today, $TODAY_HUMAN.

Gather context from everything you can reach:
- Obsidian daily notes from the last $LOOKBACK_DAYS days under: $DAILY_NOTES_DIR
  Carry forward unfinished \`- [ ]\` items, especially older ones I may have forgotten.
- Gmail: recent unread / important threads from the last $LOOKBACK_DAYS days that need a reply or action.
- Google Calendar: today's events (so the list accounts for meeting load).
- GitHub: PRs assigned to me, review requests, recently failing CI on my branches.
- Slack: unread mentions and DMs from the last $LOOKBACK_DAYS days.

Be thorough about *past* items I may have dropped, not just today's fresh things.

Output rules — follow exactly:
- At most $MAX_ITEMS items. Be ruthless about cutting; succinct beats complete.
- Sort by priority, highest first.
- One line per item, in this exact format:
    - [ ] (TIME) task description
  TIME examples: 15m, 30m, 1h, 2h. Estimate realistically for actual completion.
- If an item really needs context, add ONE short indented line under it (no more).
- Do NOT include any preamble, summary, headers, or closing remarks. Output the list and nothing else.
EOF
)

# --- Run Claude -------------------------------------------------------------
# bypassPermissions lets MCP read-tools run without interactive prompts.
LIST_OUTPUT="$(claude -p "$PROMPT")"

if [ -z "${LIST_OUTPUT//[[:space:]]/}" ]; then
  echo "Empty output from claude — aborting without modifying daily note." >&2
  exit 1
fi

# --- Append to daily note ---------------------------------------------------
if [ ! -f "$DAILY_NOTE" ]; then
  printf '# %s\n' "$TODAY" > "$DAILY_NOTE"
fi

{
  printf '\n%s\n\n' "$SECTION_HEADER"
  printf '%s\n' "$LIST_OUTPUT"
} >> "$DAILY_NOTE"

echo "Appended section to $DAILY_NOTE"
echo "===== $(date -Is) done ====="
